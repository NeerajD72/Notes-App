<div class="viewnote-wrapper">

  <div class="viewnote-topbar">
    <nav class="viewnote-breadcrumb">
      <a href="/dashboard">Dashboard</a>
      <span>/</span>
      <span><%= notes.title %></span>
    </nav>
    <button type="button" class="viewnote-delete-btn" data-bs-toggle="modal" data-bs-target="#deleteModal">
      Delete
    </button>
  </div>

  <form action="/dashboard/item/<%= noteID %>?_method=PUT" method="POST" class="viewnote-form">
    <input
      type="text"
      class="viewnote-title-input"
      id="title"
      name="title"
      value="<%= notes.title %>"
      placeholder="Title"
    >
    <textarea
      class="viewnote-body-input"
      id="body"
      name="body"
      placeholder="Write your note here..."
      rows="14"
    ><%= notes.body %></textarea>
    <div class="viewnote-actions">
      <a href="/dashboard" class="viewnote-back-btn">← Back</a>
      <button type="submit" class="viewnote-save-btn">Save Changes</button>
    </div>
  </form>

</div>

<div class="modal fade" tabindex="-1" role="dialog" id="deleteModal">
  <div class="modal-dialog" role="document">
    <div class="modal-content viewnote-modal">
      <div class="modal-header border-0">
        <h5 class="modal-title">Delete this note?</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        Are you sure you want to delete <b><%= notes.title %></b>? This cannot be undone.
      </div>
      <div class="modal-footer border-0">
        <button type="button" class="viewnote-back-btn" data-bs-dismiss="modal">Cancel</button>
        <form action="/dashboard/item-delete/<%= noteID %>?_method=DELETE" method="POST">
          <button type="submit" class="viewnote-delete-confirm-btn">Yes, Delete</button>
        </form>
      </div>
    </div>
  </div>
</div>